# The prototype starts in mock mode and requires no cloud credentials.
KUBERNETICA_ENV=development
KUBERNETICA_MODE=mock
KUBERNETICA_DATABASE_URL=sqlite+aiosqlite:///./data/kubernetica.db
KUBERNETICA_LOG_LEVEL=INFO
KUBERNETICA_RETAIN_TRANSCRIPTS=false
KUBERNETICA_RETAIN_AUDIO=false
KUBERNETICA_ALLOWED_ORIGINS=http://localhost:3000

# Turn detection defaults; tune from measured replay data.
KUBERNETICA_VAD_STOP_SECS=0.20
KUBERNETICA_TURN_FALLBACK_SECS=0.65
KUBERNETICA_BARGE_IN_DEBOUNCE_MS=120

# Optional cloud mode. No automatic paid fallback is allowed.
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

NEXT_PUBLIC_AGENT_HTTP_URL=http://localhost:8000
NEXT_PUBLIC_AGENT_WEBRTC_URL=http://localhost:8000/api/offer
